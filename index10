<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Thrive Collective - Mural Map</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="css/style.css" />
  </head>
  <body>
    <div id="app">
      <aside id="sidebar">
        <button id="sidebarHideBtn" class="sidebar-hide-btn" aria-label="Hide sidebar">
          <span>‹</span>
        </button>
        <header class="sidebar-header">
          <img src="ThriveCollective_BlackLogoHorizontal.png" alt="Thrive Collective" class="logo" />
        </header>

        <div class="sidebar-content">
        <section class="utility-panel">
          <div class="utility-headline">
            <p>Plan your visit on the go.</p>
          </div>
          <div class="nearest-actions">
            <button id="locateMeBtn" class="primary-btn">Find murals near me</button>
            <button id="clearLocationBtn" class="ghost-btn">Clear</button>
          </div>
          <div id="nearestResults" class="nearest-results empty">
            <p>Tap “Find murals near me” to surface the closest murals and walking directions.</p>
          </div>
        </section>

        <section class="filters">
          <div class="filter-group">
            <label>Mural View</label>
            <div class="filter-scroll-container">
              <div class="filter-scroll" id="muralViewFilter">
                <button class="filter-btn active" data-value="100">100%</button>
                <button class="filter-btn" data-value="75">75%</button>
                <button class="filter-btn" data-value="50">50%</button>
                <button class="filter-btn" data-value="25">25%</button>
              </div>
            </div>
          </div>

          <div class="filter-group">
            <label for="searchInput">Search</label>
            <input type="text" id="searchInput" placeholder="Search murals..." />
          </div>

          <div class="filter-group">
            <label>Year</label>
            <div class="filter-scroll-container">
              <div class="filter-scroll" id="yearFilter">
                <!-- Year buttons will be auto-populated -->
              </div>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-header">
              <label>Schools / Sites</label>
              <button class="view-all-btn" id="schoolsViewAll">View all</button>
            </div>
            <div class="filter-scroll-container">
              <div class="filter-scroll" id="schoolsFilter">
                <!-- School buttons will be auto-populated -->
              </div>
            </div>
          </div>

          <div class="filter-group">
            <div class="filter-header">
              <label>Borough</label>
              <button class="view-all-btn" id="boroughViewAll">View all</button>
            </div>
            <div class="filter-scroll-container">
              <div class="filter-scroll" id="boroughFilter">
                <!-- Borough buttons will be auto-populated -->
              </div>
            </div>
          </div>
        </section>

        <section class="tours-panel">
          <div class="filter-header">
            <label>Curated Tours</label>
          </div>
          <p class="tours-panel-subtitle">
            Quick, staff-editable routes that chain murals by borough. Use them as starting points for walking tours.
          </p>
          <div id="tourCards" class="tour-card-grid">
            <!-- Populated via JS -->
          </div>
        </section>
        </div>

        <footer class="sidebar-footer">
          <button id="resetViewBtn" class="reset-view-btn">Reset View</button>
        </footer>
      </aside>

      <!-- Modal for View All popups -->
      <div id="viewAllModal" class="modal hidden">
        <div class="modal-content">
          <div class="modal-header">
            <h2 id="modalTitle">View All</h2>
            <button class="modal-close" id="modalClose">&times;</button>
          </div>
          <div class="modal-body" id="modalBody">
            <!-- Content will be populated dynamically -->
          </div>
        </div>
      </div>

      <main id="map-container">
        <div id="map"></div>
        <div id="map-loading">Loading murals…</div>
        <div id="map-error" class="hidden">
          There was a problem loading mural data. Check the CSV URL or network connection.
        </div>
      </main>

      <!-- Fixed Mural Detail Panel -->
      <div id="muralDetailPanel" class="mural-detail-panel hidden">
        <!-- Content will be populated dynamically -->
      </div>

      <button
        id="sidebarShowTab"
        class="sidebar-show-tab hidden"
        aria-label="Show sidebar"
        aria-expanded="false"
      >
        <span>›</span>
      </button>
    </div>

    <!-- Config (CSV URL, defaults, etc.) -->
    <script src="js/config.js"></script>
    <!-- MarkerClusterer library for clustering -->
    <script src="https://unpkg.com/@googlemaps/markerclusterer/dist/index.min.js"></script>
    <!-- Map logic -->
    <script src="js/map.js"></script>

    <!-- Google Maps JavaScript API -->
    <script
      async
      src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCCXEYHeNvjT9QqTGLHU4VATLUGcS2WPuU&callback=initMap"
    ></script>
  </body>
</html>
